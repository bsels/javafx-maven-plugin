<?import javafx.scene.paint.Color?>
<?import java.lang.Object?>
<Object xmlns:fx="http://javafx.com/fxml">
    <fx:define>
        <Color fx:id="attributes" red="1.0" green="0.5" blue="0.01"/>
        <Color fx:id="elements">
            <red>0.5</red>
            <green>1.0</green>
            <blue>0.5</blue>
        </Color>
    </fx:define>
</Object>